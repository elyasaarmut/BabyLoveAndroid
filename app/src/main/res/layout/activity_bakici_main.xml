<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/backgroundColor"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarBakiciMain"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Bakıcı Paneli (Aileler)"
            app:titleTextColor="@color/textPrimary"
            app:titleCentered="true" />
    </com.google.android.material.appbar.AppBarLayout>

    <TextView
        android:id="@+id/tvWelcomeBakici"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hoş Geldiniz"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Size atanan aileler aşağıda listelenmiştir. İşlem yapmak için ailenin üzerine tıklayın."
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFamilyList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEditProfile"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_primary"
        android:text="⚙️ Profilimi Düzenle"
        android:textAllCaps="false"
        android:textColor="@color/textOnPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#FF9800"
        app:cornerRadius="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_button_secondary"
        android:text="🚪 Çıkış Yap"
        android:textAllCaps="false"
        android:textColor="@color/textOnPrimary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:cornerRadius="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp" />

</LinearLayout>
