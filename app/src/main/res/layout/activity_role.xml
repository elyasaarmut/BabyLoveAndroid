<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarRole"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/backgroundColor"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/textPrimary" />

    <!-- İçerik -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_baby_logo"
                android:contentDescription="Baby Love"
                android:layout_marginBottom="16dp" />

            <!-- Hoş Geldiniz -->
            <TextView
                android:id="@+id/tvWelcomeFamily"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoş Geldiniz! 👶"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panelinizi seçin"
                android:textSize="15sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="36dp" />

            <!-- Veli Kartı -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_role_parent"
                        android:contentDescription="Veli"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_veli"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/veli_desc"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVeli"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Veli Paneline Gir"
                        android:background="@drawable/bg_button_primary"
                        app:backgroundTint="@null"
                        app:cornerRadius="14dp"
                        android:textColor="@color/textOnPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bakıcı Kartı -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_role_caregiver"
                        android:contentDescription="Bakıcı"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_bakici"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/textPrimary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bakici_desc"
                        android:textSize="13sp"
                        android:textColor="@color/textSecondary"
                        android:layout_marginBottom="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBakici"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Bakıcı Paneline Gir"
                        android:background="@drawable/bg_button_secondary"
                        app:backgroundTint="@null"
                        app:cornerRadius="14dp"
                        android:textColor="@color/textOnPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Çıkış Yap -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="🚪 Çıkış Yap / Hesap Değiştir"
                android:textColor="@color/errorColor"
                android:textSize="14sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/backgroundColor"
                app:strokeColor="@color/errorColor"
                app:strokeWidth="1dp"
                app:cornerRadius="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
