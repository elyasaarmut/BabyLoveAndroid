<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundColor">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/backgroundColor"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarBakiciSec"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Bakıcı Seç"
            app:titleTextColor="@color/textPrimary"
            app:titleCentered="true"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/textPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/surfaceColor">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sistemdeki Bakıcılar"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etFilterCity"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Şehir Ara..."
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                android:inputType="textCapWords" />

            <Spinner
                android:id="@+id/spinnerFilterGender"
                android:layout_width="120dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFilter"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Ara"
                android:background="@drawable/bg_button_primary"
                app:backgroundTint="@null"
                android:textColor="@color/textOnPrimary"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBakiciList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>
