<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.BabyLove" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryVariant">@color/primaryDarkColor</item>
        <item name="colorOnPrimary">@color/textOnPrimary</item>
        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="colorSecondaryVariant">@color/secondaryDarkColor</item>
        <item name="colorOnSecondary">@color/textOnPrimary</item>
        <item name="android:colorBackground">@color/backgroundColor</item>
        <item name="colorSurface">@color/surfaceColor</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorError">@color/errorColor</item>
        <item name="android:statusBarColor">@color/backgroundColor</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/surfaceColor</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Shape overrides -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeSmall</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeMedium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeLarge</item>

        <!-- Button style -->
        <item name="materialButtonStyle">@style/BabyLoveButton</item>
        <item name="materialCardViewStyle">@style/BabyLoveCard</item>
    </style>

    <style name="Theme.BabyLove" parent="Base.Theme.BabyLove" />

    <!-- Shapes -->
    <style name="ShapeSmall" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeMedium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>
    <style name="ShapeLarge" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">20dp</item>
    </style>

    <!-- Primary Button -->
    <style name="BabyLoveButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/primaryColor</item>
        <item name="android:textColor">@color/textOnPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Secondary / Outlined Button -->
    <style name="BabyLoveButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/primaryLightColor</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/primaryColor</item>
    </style>

    <!-- Card -->
    <style name="BabyLoveCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/cardColor</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.BabyLove.Splash" parent="Theme.BabyLove">
        <item name="android:windowBackground">@color/backgroundColor</item>
    </style>
</resources>
