<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.BabyLove">

        <!-- Splash Screen (LAUNCHER) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BabyLove.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity android:name=".ui.LoginActivity" android:exported="false" />

        <!-- Role Selection (Removed/Disabled, kept for reference if needed, but not exported) -->
        <!-- <activity android:name=".ui.RoleActivity" android:exported="false" /> -->

        <!-- Register -->
        <activity android:name=".ui.RegisterActivity" android:exported="false" />

        <!-- Bakıcı Ana Sayfa -->
        <activity android:name=".ui.BakiciMainActivity" android:exported="false" />

        <!-- Bakıcı Seç -->
        <activity android:name=".ui.BakiciSecActivity" android:exported="false" />

        <!-- Bakıcı Profil -->
        <activity android:name=".ui.BakiciProfileActivity" android:exported="false" />

        <!-- Veli Panel -->
        <activity android:name=".ui.VeliPanelActivity" android:exported="false" />

        <!-- Bakıcı Panel -->
        <activity android:name=".ui.BakiciPanelActivity" android:exported="false" />

        <!-- Calendar -->
        <activity android:name=".ui.CalendarActivity" android:exported="false" />

        <!-- Day Detail -->
        <activity android:name=".ui.DayDetailActivity" android:exported="false" />

        <!-- Growth Charts -->
        <activity android:name=".ui.GrowthChartActivity" android:exported="false" />

        <!-- Family Chat -->
        <activity android:name=".ui.ChatActivity" android:exported="false" />
    </application>
</manifest>
